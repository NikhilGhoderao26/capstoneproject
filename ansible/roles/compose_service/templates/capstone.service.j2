[Unit]
Description=CapstoneProject Docker Compose Stack
After=network.target docker.service

[Service]
Type=simple
User={{ ansible_user }}
WorkingDirectory={{ repo_path | default('/opt/capstoneproject') }}
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
Restart=always

[Install]
WantedBy=multi-user.target
